# ─── NeedItz MVP — Environment Variables ────────────────────────────────────
#
# This MVP requires NO environment variables to run on Netlify.
#
# Netlify Blobs (lead storage) is available automatically on Netlify.
# The admin PIN is hardcoded as 1234 (change in src/lib/adminAuth.ts for now).
#
# These variables are OPTIONAL and for future use only:
# ─────────────────────────────────────────────────────────────────────────────

# Public URL (used for OG image metadata)
NEXT_PUBLIC_SITE_URL=https://needitz.com

# Analytics (optional)
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_ID=

# Future: move the admin PIN here
# ADMIN_PIN=

# Future: email notifications (Resend)
# RESEND_API_KEY=
# ADMIN_EMAIL=
# FROM_EMAIL=
